# Force LF line endings on all text files so lessons render identically on
# Windows, WSL, Linux, and macOS (this repo is authored on Windows + WSL).
* text=auto eol=lf

# Explicitly treat these as text with LF endings.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.md    text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Binary files: never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
